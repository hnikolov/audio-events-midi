{
  "id": "./",
  "name": "Audio Events MIDI",
  "short_name": "Audio MIDI",
  "start_url": "./",
  "scope": "./",
  "display": "standalone",
  "display_override": [
    "standalone",
    "minimal-ui"
  ],
  "orientation": "portrait",
  "lang": "en",
  "dir": "ltr",
  "prefer_related_applications": false,
  "share_target": {
    "action": "./share-target",
    "method": "POST",
    "enctype": "multipart/form-data",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url",
      "files": [
        {
          "name": "sharedFiles",
          "accept": [
            ".aem",
            ".aep",
            ".aeps",
            "audio/*",
            "*/*",
            "application/*",
            "application/octet-stream",
            "application/json"
          ]
        },
        {
          "name": "files",
          "accept": [
            ".aem",
            ".aep",
            ".aeps",
            "audio/*",
            "*/*",
            "application/*",
            "application/octet-stream",
            "application/json"
          ]
        }
      ]
    }
  },
  "background_color": "#0f0f0f",
  "theme_color": "#0f0f0f",
  "icons": [
    {
      "src": "icon.svg",
      "sizes": "any",
      "type": "image/svg+xml",
      "purpose": "any"
    },
    {
      "src": "icon-192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "any maskable"
    },
    {
      "src": "icon-512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "any maskable"
    }
  ]
}
